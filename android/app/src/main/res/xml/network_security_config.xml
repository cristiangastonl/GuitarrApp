<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Configuración de seguridad de red -->
    
    <!-- Configuración base para todas las conexiones -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <!-- Solo confiar en CAs del sistema -->
            <certificates src="system"/>
        </trust-anchors>
    </base-config>
    
    <!-- Configuraciones específicas para dominios permitidos -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">api.spotify.com</domain>
        <domain includeSubdomains="true">accounts.spotify.com</domain>
        
        <pin-set expiration="2025-12-31">
            <!-- Certificate pinning para APIs críticas -->
            <!-- Estos hashes deben actualizarse según los certificados reales -->
            <pin digest="SHA-256">AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=</pin>
            <pin digest="SHA-256">BBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBB=</pin>
        </pin-set>
        
        <trust-anchors>
            <certificates src="system"/>
        </trust-anchors>
    </domain-config>
    
    <!-- Configuración para desarrollo (solo en debug) -->
    <debug-overrides>
        <trust-anchors>
            <certificates src="system"/>
            <!-- En desarrollo, permitir certificados de usuario para testing -->
            <certificates src="user"/>
        </trust-anchors>
    </debug-overrides>
</network-security-config>